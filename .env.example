# Flask
FLASK_APP=app.py
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-me-to-a-random-secret-string-in-production

# JWT
JWT_SECRET_KEY=change-me-to-another-random-secret-string

# Database  (SQLite – file will be auto-created)
DATABASE_URL=sqlite:///hms.db

# Redis  (default local install)
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Cache TTL in seconds
CACHE_TTL=300

# Admin seed credentials
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@hospital.com
ADMIN_PASSWORD=Admin@123

# Email (Gmail SMTP example – used by Celery tasks)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com

#go to: https://myaccount.google.com/apppasswords
#create a new app, copy password, and save it here witout spaces.

# Google Chat Webhook (optional – for appointment reminders)
GOOGLE_CHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/XXXX/messages?key=XXXX&token=XXXX

# CSV export folder (relative to backend/)
EXPORT_FOLDER=exports
